{
  "name": "@bgskinner2/axiom-kit",
  "private": true,
  "description": "High-performance TypeScript utility monorepo",
  "author": "Brennan Skinner",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "ts-patch install",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"packages/**/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx,js,json,md}\"",
    "clean": "rimraf packages/*/dist && rimraf packages/*/node_modules",
    "inspect:linter": "npx @eslint/config-inspector",
    "sync:license": "tsx tools/scripts/sync-license.ts"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-patch": "^3.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgskinner3/axiom-kit"
  },
  "bugs": {
    "url": "https://github.com"
  },
  "homepage": "https://github.com/bgskinner3/axiom-kit",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "glob": "^11.0.0",
      "inflight": "npm:lru-cache@^10.0.0"
    }
  }
}
