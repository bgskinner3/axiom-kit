{
  "name": "axiom-kit",
  "private": true,
  "description": "High-performance TypeScript utility monorepo",
  "author": "Brennan Skinner",
  "license": "ISC",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "ts-patch install",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"packages/**/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx,js,json,md}\"",
    "clean": "rimraf packages/*/dist && rimraf packages/*/node_modules",
    "generate:list": "tsx tools/scripts/generate-utils-list.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-patch": "^3.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgskinner3/ts-kit"
  },
  "bugs": {
    "url": "https://github.com"
  },
  "homepage": "https://github.com/bgskinner3/ts-kit",
  "engines": {
    "node": ">=18.0.0"
  }
}