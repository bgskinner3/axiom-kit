{
  "compilerOptions": {
    /* Target & Module */
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "ESNext.AsyncIterable"],
    
    /* Strictness - The "Axiom" Pillar */
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,

    /* Output & Performance */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    
    /* Interop & Modernity */
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "stripInternal": true,
    
    /* Path Mapping for the Monorepo */
    "paths": {
      "@axiom/*": ["./packages/*/src"]
    }
  }
}