{
  "compilerOptions": {
    /* Target & Module */
    "target": "ESNext",
    "module": "ESNext", // 👈 Critical: Handles ESM/CJS correctly
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "ESNext.AsyncIterable"
    ],
    /* Strictness - The "Axiom" Pillar */
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    /* Output & Performance */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    /* Interop & Modernity */
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "stripInternal": true, // 👈 Keeps your public API clean (Wizard-level)
    "verbatimModuleSyntax": true, // 👈 TS 5.0+ standard for cleaner ESM imports
    /* Path Mapping for the Monorepo */
    "paths": {
      "@axiom/utility-types": [
        "./packages/utility-types"
      ],
      "@axiom/core": [
        "./packages/core"
      ],
      "@axiom/guards": [
        "./packages/guards"
      ],
      "@axiom/react": [
        "./packages/react"
      ]
    }
  }
}