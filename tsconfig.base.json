{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "ESNext.AsyncIterable"
    ],
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@bgskinner2/axiom-kit-utility-types": [
        "./packages/utility-types"
      ],
      "@bgskinner2/axiom-kit-guards": [
        "./packages/guards"
      ],
      "@bgskinner2/axiom-kit-core": [
        "./packages/core"
      ],
      "@bgskinner2/axiom-kit-colors": [
        "./packages/colors"
      ],
      "@bgskinner2/axiom-kit-morph": [
        "./packages/morph"
      ],
      "@bgskinner2/axiom-kit-dom": [
        "./packages/dom"
      ],
      "@bgskinner2/axiom-kit-deep-operations": [
        "./packages/deep-operations"
      ],
      "@bgskinner2/axiom-kit-react": [
        "./packages/react"
      ],
      "@bgskinner2/debug": [
        "./packages/debug"
      ],
      "@bgskinner2/regex-engine": [
        "./packages/regex-engine"
      ],
      "@bgskinner2/xalor": [
        "./packages/xalor"
      ]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tools/**/*.ts",
    "playground/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist"
  ]
}