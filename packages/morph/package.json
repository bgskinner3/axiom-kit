{
  "name": "@bgskinner2/axiom-kit-morph",
  "version": "1.0.0",
  "description": "High-performance data transformation, key mapping, and casing engines.",
  "author": "Brennan Skinner",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest --config jest.config.cjs",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@bgskinner2/axiom-kit-core": "workspace:*",
    "@bgskinner2/axiom-kit-utility-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1"
  },
  "keywords": [
    "typescript",
    "morph",
    "casing",
    "transformation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgskinner3/axiom-kit",
    "directory": "packages/morph"
  },
  "bugs": {
    "url": "https://github.com/bgskinner3/axiom-kit"
  },
  "homepage": "https://github.com/bgskinner3/axiom-kit",
  "engines": {
    "node": ">=18.0.0"
  }
}
