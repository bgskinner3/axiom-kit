{
  "name": "@axiom/morph",
  "version": "1.0.0",
  "description": "High-performance data transformation, key mapping, and casing engines.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest --config jest.config.cjs",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@axiom/core": "workspace:*",
    "@axiom/utility-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1"
  },
  "keywords": [
    "typescript",
    "morph",
    "casing",
    "transformation"
  ]
}
