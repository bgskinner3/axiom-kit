{
  "name": "@axiom/dom",
  "version": "1.0.0",
  "description": "High-performance Web API orchestrators and browser-only utilities.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "dependencies": {
    "@axiom/guards": "workspace:*",
    "@axiom/utility-types": "workspace:*"
  },
  "keywords": [
    "typescript",
    "dom",
    "browser",
    "axiom"
  ]
}
