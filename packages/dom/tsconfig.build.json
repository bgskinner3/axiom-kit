{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "composite": false, // 👈 MUST be false
    "incremental": false, // 👈 MUST be false
    "tsBuildInfoFile": null, // 👈 Ensures no stale cache files
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__",
    "**/*.test.ts"
  ]
}