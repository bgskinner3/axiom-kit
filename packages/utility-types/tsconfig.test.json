{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": [
    "src/**/*",
    "__tests__/**/*"
  ],
  "exclude": [
    "**/__tests__/utils/**/*"
  ]
}