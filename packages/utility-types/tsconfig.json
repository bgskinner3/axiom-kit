{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist",
    "composite": true,
    "incremental": true,
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "**/__tests__/utils/**/*"
  ],
  "exclude": [
    "dist",
  ]
}