{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "outDir": "./dist",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "noEmit": false,
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "noImplicitAny": false,
    "isolatedModules": false,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@bgskinner2/xalor/generated": [
        "./node_modules/@bgskinner2/xalor/dist/generated/solid-env.d.ts"
      ]
    }
  },
  "ignoreDiagnostics": [
    5023,
    5024,
    5039,
    5072,
    5103
  ],
  "include": [
    "src/**/*",
    "transformer/**/*",
    "shared/**/*",
    "tsup.config.ts",
    "__tests__",
    "dist/solid-env.d.ts",
    "node_modules/@bgskinner2/xalor/dist/generated/solid-env.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}