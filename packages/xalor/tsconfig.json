{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": false, // ✨ Set to false to avoid project reference strictness
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "noEmit": false,
    // 🚨 THE CRITICAL OVERRIDES
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "noImplicitAny": false, // ✨ Fixes the 'ctx' any errors
    "isolatedModules": false,
    "types": [
      "node",
      "jest"
    ]
  },
  "ignoreDiagnostics": [
    5023,
    5024,
    5039,
    5072,
    5103
  ],
  "include": [ // DO NOT REMOVE CAUSES ERROS
    "src/**/*",
    "transformer/**/*",
    "models/**/*",
    "tsup.config.ts",
    "__tests__"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}