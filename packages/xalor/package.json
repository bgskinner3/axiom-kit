{
  "name": "@bgskinner2/xalor",
  "description": "Ambient runtime type database for TypeScript. Solidifies ghost types into a global vault.",
  "version": "0.0.1-alpha.1",
  "author": "Brennan Skinner",
  "license": "MIT",
  "type": "module",
  "typescript": {
    "plugins": [
      {
        "transform": "./dist/transformer/index.cjs",
        "type": "program"
      }
    ]
  },
  "sideEffects": [
    "./transformer/reifiers/registry/*.ts"
  ],
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./transformer": {
      "types": "./dist/transformer.d.ts",
      "import": "./dist/transformer.js",
      "require": "./dist/transformer.cjs"
    },
    "./generated": {
      "types": "./dist/generated/solid-env.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "ts-patch install -s",
    "build": "tsup",
    "test": "npm run build && jest"
  },
  "dependencies": {
    "ts-patch": "^3.3.0",
    "tslib": "^2.6.2"
  },

  "peerDependencies": {
    "typescript": ">=5.0.0"
  },

  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgskinner3/axiom-kit/tree/main/packages/xalor",
    "directory": "packages/xalor"
  },
  "bugs": {
    "url": "https://github.com/bgskinner3/axiom-kit/tree/main/packages/xalor"
  },
  "homepage": "https://github.com/bgskinner3/axiom-kit"
}
