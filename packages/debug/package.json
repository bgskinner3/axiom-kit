{
  "name": "@axiom/debug",
  "version": "1.0.0",
  "description": "High-resolution diagnostics and developer-only auditing tools.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@axiom/core": "workspace:*",
    "@axiom/utility-types": "workspace:*"
  },
  "private": true
}
