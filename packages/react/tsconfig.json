{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    /* 1. The React Engine */
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    /* 2. Framework Isolation */
    "types": [
      "react",
      "react-dom",
      "node",
      "jest"
    ],
    /* 3. Performance */
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "references": [
    {
      "path": "../utility-types"
    },
    {
      "path": "../core"
    },
    {
      "path": "../guards"
    }
  ],
  "include": [
    "src",
    "__tests__/**/*"
  ],
  "exclude": [
    "dist"
  ]
}