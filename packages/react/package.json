{
  "name": "@axiom/react",
  "version": "1.0.0",
  "description": "High-performance React utilities and type guards for the Axiom kit.",
  "author": "Brennan Skinner",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest --config jest.config.cjs",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@axiom/core": "workspace:*",
    "@axiom/guards": "workspace:*",
    "@axiom/utility-types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "keywords": [
    "typescript",
    "react",
    "guards",
    "axiom"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1"
  }
}
