{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "noEmit": false,
    "tsBuildInfoFile": null,
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "__tests__",
    "__test__",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test-d.ts"
  ]
}