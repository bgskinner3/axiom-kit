{
  "name": "@axiom/deep-operations",
  "version": "1.0.0",
  "description": "High-performance recursive tree manipulation and deep object surgery.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "dependencies": {
    "@axiom/guards": "workspace:*",
    "@axiom/utility-types": "workspace:*"
  }
}
