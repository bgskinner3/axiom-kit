{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "is-solid": [
        "../src/index.ts"
      ]
    },
    "plugins": [
      {
        "transform": "../transformer/index.ts",
        "type": "program"
      }
    ]
  },
  "include": [
    "index.ts",
    "../models/**/*",
    "../src/**/*.ts"
  ]
}