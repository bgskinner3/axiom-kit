{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // We remove "rootDir": "src" so both folders are included
    "outDir": "dist",
    "declaration": true,
    "composite": false,
    "incremental": false,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*",
    "transformer/**/*",
    "models/**/*"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/playground/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "jest.config.cjs"
  ]
}