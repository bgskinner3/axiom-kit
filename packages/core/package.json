{
  "name": "@axiom/core",
  "version": "1.0.0",
  "description": "Foundational logic, shared constants, and resilience utilities for the Axiom kit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "dependencies": {
    "@axiom/utility-types": "workspace:*"
  },
  "keywords": [
    "typescript",
    "core",
    "logic",
    "resilience"
  ]
}