{
  "name": "@axiom/core",
  "version": "1.0.0",
  "description": "Foundational logic, shared constants, and resilience utilities for the Axiom kit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "dependencies": {
    "@axiom/utility-types": "workspace:*"
  },
  "keywords": [
    "typescript",
    "core",
    "logic",
    "resilience"
  ]
}
