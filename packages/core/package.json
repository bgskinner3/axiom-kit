{
  "name": "@bgskinner2/axiom-kit-core",
  "version": "1.0.0",
  "description": "Foundational logic, shared constants, and resilience utilities for the Axiom kit.",
  "author": "Brennan Skinner",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "keywords": [
    "typescript",
    "core",
    "logic",
    "resilience"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com"
  },
  "homepage": "https://github.com",
  "engines": {
    "node": ">=18.0.0"
  }
}
