  // Ensure the extension looks for the /* glsl */ tag
  "webgl-glsl-editor.format.enabled": true,
  "tailwindCSS.experimental.classRegex": [
    [
      "cn\\(([^)]*)\\)",
      "(?:'|\"|`)([^'\"`]*)(?:'|\"|`)"
    ],
    [
      "cva\\(([^)]*)\\)",
      "[\"'`]([^\"'`]* archival)[\"'`]"
    ]
  ],
