{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true, // 💎 MUST BE TRUE: Stops checking linked library files
    "noEmit": false,
    "paths": {
      "@bgskinner2/xalor": [
        "../packages/xalor/src/index.ts"
      ]
    },
    "plugins": [
      {
        "transform": "../packages/xalor/dist/transformer/index.cjs",
        "type": "program"
      }
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "../packages/xalor/__tests__"
  ] // 💎 IGNORE THE TESTS
}