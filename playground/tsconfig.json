{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "ignoreDeprecations": "5.0",
    "paths": {
      "is-solid": [
        "../packages/is-solid/dist/index.d.ts"
      ]
    },
    "plugins": [
      {
        "transform": "../packages/is-solid/dist/transformer/index.cjs",
        "type": "program"
      }
    ]
  },
  "include": [
    "src/**/*",
  ]
}