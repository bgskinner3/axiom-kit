{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    // 💎 FIX 1: Lock rootDir to the playground only. 
    // This stops it from building your library files.
    "rootDir": "./src",
    "skipLibCheck": true,
    "noEmit": false,
    "ignoreDeprecations": "6.0",
    "paths": {
      // 💎 FIX 2: Point to the DIST folder, not the SRC folder.
      // This ensures the playground "consumes" the built library.
      "@bgskinner2/xalor": [
        "../packages/xalor/dist/index.d.ts",
        "../packages/xalor/dist/index.js"
      ]
    },
    "plugins": [
      {
        "transform": "../packages/xalor/dist/transformer/index.cjs",
        "type": "program"
      }
    ]
  },
  "include": [
    "src/main.ts"
  ],
}